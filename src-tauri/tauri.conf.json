{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "site2pdf",
  "version": "0.2.0",
  "identifier": "com.antigravity.site2pdf",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "site2PDF",
        "width": 540,
        "height": 460,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
